# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAILJS CONFIGURATION
# VITE_EMAILJS_PUBLIC_KEY: Your EmailJS account Public Key (from Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY="Dx4w5vuSqlKWbxflR"
# VITE_EMAILJS_SERVICE_ID: Your custom email service ID (e.g. service_xxxxxxx)
VITE_EMAILJS_SERVICE_ID="service_45eiglk"
# VITE_EMAILJS_TEMPLATE_ID: Your primary submission email template
VITE_EMAILJS_TEMPLATE_ID="template_0ecv4ad"
# VITE_EMAILJS_TEMPLATE_CONFIRM_ID: Your approval/rejection decision email template
VITE_EMAILJS_TEMPLATE_CONFIRM_ID="template_e2h2dfp"
# Optional: Separate templates if you want different layouts for Accept vs Reject
VITE_EMAILJS_TEMPLATE_ACCEPT_ID=""
VITE_EMAILJS_TEMPLATE_REJECT_ID=""

